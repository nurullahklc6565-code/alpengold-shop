generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// COĞRAFYA & PARA BİRİMİ
// ─────────────────────────────────────────────────────────────────────────────

model Country {
  id        String   @id @default(cuid())
  name      String
  codeIso2  String   @unique @map("code_iso2")
  codeIso3  String   @unique @map("code_iso3")
  phoneCode String   @map("phone_code")
  flagEmoji String?  @map("flag_emoji")
  active    Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  marketCountries        MarketCountry[]
  shippingZoneCountries  ShippingZoneCountry[]
  taxRules               TaxRule[]
  addresses              Address[]
  customers              Customer[]

  @@map("countries")
}

model Currency {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  symbol        String
  decimalDigits Int      @default(2) @map("decimal_digits")
  active        Boolean  @default(false)
  createdAt     DateTime @default(now()) @map("created_at")

  markets              Market[]
  productVariantPrices ProductVariantPrice[]
  shippingRates        ShippingRate[]
  payments             Payment[]
  orders               Order[]
  invoices             Invoice[]

  @@map("currencies")
}

// ─────────────────────────────────────────────────────────────────────────────
// PAZAR (MARKET) SİSTEMİ
// ─────────────────────────────────────────────────────────────────────────────

enum FallbackPricing {
  BLOCK          // Bu pazarda fiyat tanımlı değil → satışa kapat
  USE_BASE_PRICE // variant.base_price kullan
  USE_DEFAULT    // varsayılan pazarın fiyatını kullan
}

model Market {
  id                String          @id @default(cuid())
  name              String
  slug              String          @unique
  defaultCurrencyId String          @map("default_currency_id")
  isDefault         Boolean         @default(false) @map("is_default")
  active            Boolean         @default(true)
  fallbackPricing   FallbackPricing @default(BLOCK) @map("fallback_pricing")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  defaultCurrency        Currency               @relation(fields: [defaultCurrencyId], references: [id])
  marketCountries        MarketCountry[]
  marketPaymentProviders MarketPaymentProvider[]
  productVariantPrices   ProductVariantPrice[]
  shippingZones          ShippingZone[]
  taxRules               TaxRule[]               // pazar bazlı vergi override'ları
  orders                 Order[]

  @@map("markets")
}

model MarketCountry {
  marketId  String @map("market_id")
  countryId String @map("country_id")

  market  Market  @relation(fields: [marketId], references: [id], onDelete: Cascade)
  country Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@id([marketId, countryId])
  @@map("market_countries")
}

model MarketPaymentProvider {
  marketId           String @map("market_id")
  paymentProviderId  String @map("payment_provider_id")
  active             Boolean @default(true)

  market          Market          @relation(fields: [marketId], references: [id], onDelete: Cascade)
  paymentProvider PaymentProvider @relation(fields: [paymentProviderId], references: [id], onDelete: Cascade)

  @@id([marketId, paymentProviderId])
  @@map("market_payment_providers")
}

// ─────────────────────────────────────────────────────────────────────────────
// ÜRÜN SİSTEMİ
// ─────────────────────────────────────────────────────────────────────────────

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  parentId  String?   @map("parent_id")
  imageUrl    String?   @map("image_url")
  description String?
  featured    Boolean   @default(false)
  active      Boolean   @default(true)
  position  Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]

  @@map("categories")
}

model Collection {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  imageUrl    String?  @map("image_url")
  active      Boolean  @default(true)
  position    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  productCollections ProductCollection[]

  @@map("collections")
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model Product {
  id             String        @id @default(cuid())
  name           String
  slug           String        @unique
  description    String?
  categoryId     String?       @map("category_id")
  status         ProductStatus @default(DRAFT)
  taxClass       String        @default("standard") @map("tax_class")
  vendor         String?
  productType    String?       @map("product_type")
  tags           String[]      @default([])
  seoTitle       String?       @map("seo_title")
  seoDescription String?       @map("seo_description")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  category           Category?           @relation(fields: [categoryId], references: [id])
  productCollections ProductCollection[]
  images             ProductImage[]
  variants           ProductVariant[]
  wishlists          Wishlist[]

  @@map("products")
}

model ProductCollection {
  productId    String @map("product_id")
  collectionId String @map("collection_id")
  position     Int    @default(0)

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([productId, collectionId])
  @@map("product_collections")
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String  @map("product_id")
  url       String
  alt       String?
  position  Int     @default(0)
  isPrimary Boolean @default(false) @map("is_primary")

  product  Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  variants ProductVariant[]

  @@map("product_images")
}

model ProductVariant {
  id               String   @id @default(cuid())
  productId        String   @map("product_id")
  sku              String   @unique
  barcode          String?
  options          Json     @default("{}")
  basePrice        Decimal  @map("base_price") @db.Decimal(12, 2)
  compareAtPrice   Decimal? @map("compare_at_price") @db.Decimal(12, 2)
  weight           Decimal? @db.Decimal(8, 3)
  lengthCm         Decimal? @map("length_cm") @db.Decimal(8, 2)
  widthCm          Decimal? @map("width_cm") @db.Decimal(8, 2)
  heightCm         Decimal? @map("height_cm") @db.Decimal(8, 2)
  imageId          String?  @map("image_id")
  active           Boolean  @default(true)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  product        Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  image          ProductImage?        @relation(fields: [imageId], references: [id])
  inventory      InventoryItem?
  prices         ProductVariantPrice[]
  orderItems     OrderItem[]
  stockMovements StockMovement[]

  @@map("product_variants")
}

model InventoryItem {
  id                String  @id @default(cuid())
  variantId         String  @unique @map("variant_id")
  trackQuantity     Boolean @default(true) @map("track_quantity")
  quantity          Int     @default(0)
  reserved          Int     @default(0)
  lowStockThreshold Int?    @map("low_stock_threshold")

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@map("inventory_items")
}

model ProductVariantPrice {
  id             String  @id @default(cuid())
  variantId      String  @map("variant_id")
  marketId       String  @map("market_id")
  currencyId     String  @map("currency_id")
  price          Decimal @db.Decimal(12, 2)
  compareAtPrice Decimal? @map("compare_at_price") @db.Decimal(12, 2)

  variant  ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  market   Market         @relation(fields: [marketId], references: [id], onDelete: Cascade)
  currency Currency       @relation(fields: [currencyId], references: [id])

  @@unique([variantId, marketId])
  @@map("product_variant_prices")
}

// ─────────────────────────────────────────────────────────────────────────────
// MÜŞTERİ & SİPARİŞ
// ─────────────────────────────────────────────────────────────────────────────

model Customer {
  id              String    @id @default(cuid())
  email           String    @unique
  firstName       String    @map("first_name")
  lastName        String    @map("last_name")
  phone           String?
  passwordHash    String?   @map("password_hash")
  countryId       String?   @map("country_id")
  emailVerified   Boolean   @default(false) @map("email_verified")
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  notes     String?   // admin notu (müşteri göremiyor)

  country   Country?   @relation(fields: [countryId], references: [id])
  addresses Address[]
  orders    Order[]
  wishlists Wishlist[]
  invoices  Invoice[]

  @@map("customers")
}

model Address {
  id         String  @id @default(cuid())
  customerId String  @map("customer_id")
  firstName  String  @map("first_name")
  lastName   String  @map("last_name")
  company    String?
  line1      String
  line2      String?
  city       String
  province   String?
  zip        String?
  countryId  String  @map("country_id")
  phone      String?
  isDefault  Boolean @default(false) @map("is_default")

  customer          Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  country           Country  @relation(fields: [countryId], references: [id])
  shippingOrders    Order[]  @relation("ShippingAddress")
  billingOrders     Order[]  @relation("BillingAddress")

  @@map("addresses")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  UNPAID
  PAID
  PARTIALLY_PAID
  REFUNDED
}

enum FulfillmentStatus {
  UNFULFILLED          // gönderilmedi
  PARTIALLY_FULFILLED  // kısmen gönderildi
  FULFILLED            // tamamı gönderildi
  RETURNED             // iade edildi
}

model Order {
  id                  String            @id @default(cuid())
  number              String            @unique
  customerId          String            @map("customer_id")
  marketId            String            @map("market_id")
  currencyId          String            @map("currency_id")
  status              OrderStatus       @default(PENDING)
  paymentStatus       PaymentStatus     @default(UNPAID) @map("payment_status")
  fulfillmentStatus   FulfillmentStatus @default(UNFULFILLED) @map("fulfillment_status")
  trackingNumber      String?           @map("tracking_number")
  carrierCode         String?           @map("carrier_code")
  totalPrice          Decimal           @map("total_price") @db.Decimal(12, 2)
  subtotalPrice       Decimal           @map("subtotal_price") @db.Decimal(12, 2)
  shippingPrice       Decimal           @default(0) @map("shipping_price") @db.Decimal(12, 2)
  taxPrice            Decimal           @default(0) @map("tax_price") @db.Decimal(12, 2)
  discountPrice       Decimal           @default(0) @map("discount_price") @db.Decimal(12, 2)
  shippingAddressId   String?           @map("shipping_address_id")
  billingAddressId    String?           @map("billing_address_id")
  notes               String?
  adminNote           String?           @map("admin_note")
  couponCode          String?           @map("coupon_code")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  customer        Customer    @relation(fields: [customerId], references: [id])
  market          Market      @relation(fields: [marketId], references: [id])
  currency        Currency    @relation(fields: [currencyId], references: [id])
  shippingAddress Address?    @relation("ShippingAddress", fields: [shippingAddressId], references: [id])
  billingAddress  Address?    @relation("BillingAddress", fields: [billingAddressId], references: [id])
  items           OrderItem[]
  payments        Payment[]
  invoice         Invoice?

  @@map("orders")
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String  @map("order_id")
  variantId  String  @map("variant_id")
  quantity   Int
  unitPrice  Decimal @map("unit_price") @db.Decimal(12, 2)
  totalPrice Decimal @map("total_price") @db.Decimal(12, 2)

  // Sipariş anındaki snapshot — ürün sonradan değişse dahi kayıt korunur
  variantSnapshot Json @map("variant_snapshot")

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// KARGO
// ─────────────────────────────────────────────────────────────────────────────

model ShippingProvider {
  id     String  @id @default(cuid())
  name   String
  code   String  @unique
  active Boolean @default(false)

  shippingRates ShippingRate[]

  @@map("shipping_providers")
}

model ShippingZone {
  id       String @id @default(cuid())
  marketId String @map("market_id")
  name     String

  market            Market                @relation(fields: [marketId], references: [id], onDelete: Cascade)
  shippingCountries ShippingZoneCountry[]
  rates             ShippingRate[]

  @@map("shipping_zones")
}

model ShippingZoneCountry {
  zoneId    String @map("zone_id")
  countryId String @map("country_id")

  zone    ShippingZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  country Country      @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@id([zoneId, countryId])
  @@map("shipping_zone_countries")
}

enum ShippingConditionType {
  FLAT
  BY_WEIGHT
  BY_ORDER_PRICE
  BY_QUANTITY
}

model ShippingRate {
  id            String                @id @default(cuid())
  zoneId        String                @map("zone_id")
  name          String
  conditionType ShippingConditionType @default(FLAT) @map("condition_type")
  minValue      Decimal?              @map("min_value") @db.Decimal(12, 3)
  maxValue      Decimal?              @map("max_value") @db.Decimal(12, 3)
  rate          Decimal               @db.Decimal(12, 2)
  currencyId    String                @map("currency_id")
  freeAbove     Decimal?              @map("free_above") @db.Decimal(12, 2)
  providerId    String?               @map("provider_id")
  active        Boolean               @default(true)

  zone     ShippingZone      @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  currency Currency          @relation(fields: [currencyId], references: [id])
  provider ShippingProvider? @relation(fields: [providerId], references: [id])

  @@map("shipping_rates")
}

// ─────────────────────────────────────────────────────────────────────────────
// VERGİ
// ─────────────────────────────────────────────────────────────────────────────

enum TaxInclusionType {
  INCLUSIVE  // fiyata dahil
  EXCLUSIVE  // fiyatın üstüne eklenir
}

model TaxRule {
  id                String           @id @default(cuid())
  name              String
  countryId         String           @map("country_id")
  // null → tüm pazarlar için geçerli global kural
  // dolu → sadece bu pazar için geçerli override
  marketId          String?          @map("market_id")
  taxClass          String           @default("standard") @map("tax_class")
  rate              Decimal          @db.Decimal(6, 4)
  inclusionType     TaxInclusionType @default(EXCLUSIVE) @map("inclusion_type")
  appliesToShipping Boolean          @default(false) @map("applies_to_shipping")
  priority          Int              @default(0)
  active            Boolean          @default(true)
  createdAt         DateTime         @default(now()) @map("created_at")

  country Country  @relation(fields: [countryId], references: [id])
  market  Market?  @relation(fields: [marketId], references: [id], onDelete: SetNull)

  @@map("tax_rules")
}

// ─────────────────────────────────────────────────────────────────────────────
// ÖDEME
// ─────────────────────────────────────────────────────────────────────────────

model PaymentProvider {
  id             String  @id @default(cuid())
  name           String
  code           String  @unique
  active         Boolean @default(false)
  settingsSchema Json    @map("settings_schema")

  marketPaymentProviders MarketPaymentProvider[]
  configs                PaymentProviderConfig[]
  payments               Payment[]

  @@map("payment_providers")
}

model PaymentProviderConfig {
  id         String  @id @default(cuid())
  providerId String  @map("provider_id")
  marketId   String? @map("market_id")
  configData Json    @map("config_data")

  provider PaymentProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, marketId])
  @@map("payment_provider_configs")
}

enum PaymentProviderStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELLED
  REFUNDED
}

model Payment {
  id                String                @id @default(cuid())
  orderId           String                @map("order_id")
  providerId        String                @map("provider_id")
  status            PaymentProviderStatus @default(PENDING)
  amount            Decimal               @db.Decimal(12, 2)
  currencyId        String                @map("currency_id")
  providerPaymentId String?               @map("provider_payment_id")
  webhookVerified   Boolean               @default(false) @map("webhook_verified")
  metadata          Json?
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")

  order    Order           @relation(fields: [orderId], references: [id])
  provider PaymentProvider @relation(fields: [providerId], references: [id])
  currency Currency        @relation(fields: [currencyId], references: [id])

  @@map("payments")
}

// ─────────────────────────────────────────────────────────────────────────────
// İNDİRİM & KUPON
// ─────────────────────────────────────────────────────────────────────────────

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
}

enum DiscountAppliesTo {
  ALL
  PRODUCT
  CATEGORY
  COLLECTION
  MARKET
}

model Discount {
  id            String            @id @default(cuid())
  name          String
  type          DiscountType
  value         Decimal           @db.Decimal(10, 4)
  appliesTo     DiscountAppliesTo @default(ALL) @map("applies_to")
  targetId      String?           @map("target_id")
  marketId      String?           @map("market_id")
  currencyId    String?           @map("currency_id")
  minOrderValue Decimal?          @map("min_order_value") @db.Decimal(12, 2)
  startsAt      DateTime          @map("starts_at")
  endsAt        DateTime?         @map("ends_at")
  active        Boolean           @default(true)
  createdAt     DateTime          @default(now()) @map("created_at")

  coupons Coupon[]

  @@map("discounts")
}

model Coupon {
  id              String   @id @default(cuid())
  code            String   @unique
  discountId      String   @map("discount_id")
  usageLimit      Int?     @map("usage_limit")
  usedCount       Int      @default(0) @map("used_count")
  onePerCustomer  Boolean  @default(false) @map("one_per_customer")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")

  discount Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)

  @@map("coupons")
}

// ─────────────────────────────────────────────────────────────────────────────
// PERSONEL, ROL & GÜVENLİK
// ─────────────────────────────────────────────────────────────────────────────

model Role {
  id   String @id @default(cuid())
  name String @unique

  staffUsers      StaffUser[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id       String @id @default(cuid())
  resource String
  action   String

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model StaffUser {
  id          String    @id @default(cuid())
  email       String    @unique
  passwordHash String   @map("password_hash")
  firstName   String    @map("first_name")
  lastName    String    @map("last_name")
  roleId      String    @map("role_id")
  active      Boolean   @default(true)
  lastLoginAt DateTime? @map("last_login_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  role           Role            @relation(fields: [roleId], references: [id])
  activityLogs   ActivityLog[]
  stockMovements StockMovement[]

  @@map("staff_users")
}

model ActivityLog {
  id         String   @id @default(cuid())
  staffId    String   @map("staff_id")
  action     String
  resource   String
  resourceId String?  @map("resource_id")
  payload    Json?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  staff StaffUser @relation(fields: [staffId], references: [id])

  @@map("activity_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// MEDYA
// ─────────────────────────────────────────────────────────────────────────────

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
}

model Media {
  id        String    @id @default(cuid())
  url       String
  key       String    @unique
  mimeType  String    @map("mime_type")
  type      MediaType
  size      Int
  width     Int?
  height    Int?
  alt       String?
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("media")
}

// ─────────────────────────────────────────────────────────────────────────────
// FAVORİLER (WISHLIST)
// ─────────────────────────────────────────────────────────────────────────────

model Wishlist {
  id         String   @id @default(cuid())
  customerId String   @map("customer_id")
  productId  String   @map("product_id")
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
  @@map("wishlists")
}

// ─────────────────────────────────────────────────────────────────────────────
// SITE AYARLARI
// ─────────────────────────────────────────────────────────────────────────────

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  group     String   @default("general")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

// ─────────────────────────────────────────────────────────────────────────────
// FATURA
// ─────────────────────────────────────────────────────────────────────────────

enum InvoiceStatus {
  DRAFT      // taslak
  ISSUED     // kesildi
  PAID       // ödendi
  CANCELLED  // iptal
}

model Invoice {
  id         String        @id @default(cuid())
  number     String        @unique             // FAT-2026-000001
  orderId    String        @unique @map("order_id")
  customerId String        @map("customer_id")
  status     InvoiceStatus @default(ISSUED)
  subtotal   Decimal       @db.Decimal(12, 2)
  taxAmount  Decimal       @map("tax_amount") @db.Decimal(12, 2)
  total      Decimal       @db.Decimal(12, 2)
  currencyId String        @map("currency_id")
  notes      String?
  dueDate    DateTime?     @map("due_date")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  order    Order    @relation(fields: [orderId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
  currency Currency @relation(fields: [currencyId], references: [id])

  @@map("invoices")
}

// ─────────────────────────────────────────────────────────────────────────────
// STOK HAREKETLERİ
// ─────────────────────────────────────────────────────────────────────────────

enum StockMovementType {
  PURCHASE    // alım
  SALE        // satış (ödeme sonrası)
  RETURN      // müşteri iadesi
  ADJUSTMENT  // manuel düzeltme
  RESERVATION // sipariş rezervasyonu
  RELEASE     // rezervasyon iptali
}

model StockMovement {
  id        String            @id @default(cuid())
  variantId String            @map("variant_id")
  type      StockMovementType
  quantity  Int               // pozitif = giriş, negatif = çıkış
  before    Int               // hareket öncesi miktar
  after     Int               // hareket sonrası miktar
  reason    String?
  reference String?           // sipariş no vb.
  staffId   String?           @map("staff_id")
  createdAt DateTime          @default(now()) @map("created_at")

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  staff   StaffUser?     @relation(fields: [staffId], references: [id])

  @@map("stock_movements")
}
