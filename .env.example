# ─────────────────────────────────────────────────────────────────────────────
# VERİTABANI
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://ecommerce:ecommerce_dev_password@localhost:5432/ecommerce"

# ─────────────────────────────────────────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─────────────────────────────────────────────────────────────────────────────
# AUTH
# ─────────────────────────────────────────────────────────────────────────────
# openssl rand -base64 32 ile üret
AUTH_SECRET="REPLACE_WITH_RANDOM_SECRET"
NEXTAUTH_URL="http://localhost:3002"

# ─────────────────────────────────────────────────────────────────────────────
# DEPOLAMA (Cloudflare R2 veya AWS S3)
# ─────────────────────────────────────────────────────────────────────────────
STORAGE_PROVIDER="local" # local (geliştirme) | r2 | s3
STORAGE_BUCKET=""
STORAGE_ACCOUNT_ID=""    # R2 için (S3'te kullanılmaz)
STORAGE_REGION=""        # S3 için (örn: eu-central-1); R2'de kullanılmaz
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_PUBLIC_URL=""    # CDN veya R2 public domain (örn: https://cdn.yourdomain.com)

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL (Resend)
# ─────────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="noreply@yourdomain.com"

# ─────────────────────────────────────────────────────────────────────────────
# ÖDEME SAĞLAYICILAR — sadece kullanacağınları doldurun
# Gerçek key olmadan gerçek ödeme işlemi yapılmaz
# ─────────────────────────────────────────────────────────────────────────────

# Stripe
# Secret key SADECE sunucu tarafında kullanılır — frontend'e gitmez
STRIPE_SECRET_KEY=""
# Publishable key tek public Stripe değeri (NEXT_PUBLIC_ prefix = frontend'e gidebilir)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Webhook secret ZORUNLU — yoksa canlı ödeme aktif olmaz
STRIPE_WEBHOOK_SECRET=""
# TRY, USD, EUR … market para birimini kullanmak için "market" yazın
STRIPE_CURRENCY_MODE="market"
# Stripe ödeme sonrası yönlendirme URL'leri
STRIPE_SUCCESS_URL="http://localhost:3002/checkout/success"
STRIPE_CANCEL_URL="http://localhost:3002/checkout/cancel"

# iyzico
IYZICO_API_KEY=""
IYZICO_SECRET_KEY=""
IYZICO_BASE_URL="https://sandbox-api.iyzipay.com"

# PayPal
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_WEBHOOK_ID=""
PAYPAL_SANDBOX="true"

# ─────────────────────────────────────────────────────────────────────────────
# UYGULAMA
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3002"
NODE_ENV="development"
